#include <stdio.h>
#include <string.h>
#include <sys/unistd.h>
#include <sys/stat.h>
#include "esp_vfs_fat.h"
#include "sdmmc_cmd.h"
#include "driver/spi_master.h"
#include "esp_log.h"

static const char *TAG = "MAIN";

#define PIN_NUM_MISO 19
#define PIN_NUM_MOSI 23
#define PIN_NUM_CLK  18
#define PIN_NUM_CS   5

void app_main(void)
{
    esp_err_t ret;

    // 1. Configure the mount options
    esp_vfs_fat_sdmmc_mount_config_t mount_config = {
        .format_if_mount_failed = false,
        .max_files = 5,
        .allocation_unit_size = 16 * 1024
    };
    
    sdmmc_card_t *card;
    const char mount_point[] = "/sdcard";
    
    ESP_LOGI(TAG, "Initializing SPI bus");

    // 2. Configure the SPI bus
    spi_bus_config_t bus_cfg = {
        .mosi_io_num = PIN_NUM_MOSI,
        .miso_io_num = PIN_NUM_MISO,
        .sclk_io_num = PIN_NUM_CLK,
        .quadwp_io_num = -1,
        .quadhd_io_num = -1,
        .max_transfer_sz = 4000,
    };
    
    // Initialize the SPI bus (SPI2_HOST is standard for ESP32)
    ret = spi_bus_initialize(SPI2_HOST, &bus_cfg, SPI_DMA_CH_AUTO);
    if (ret != ESP_OK) {
        ESP_LOGE(TAG, "Failed to initialize SPI bus.");
        return;
    }

    // 3. Configure the SD card via SPI
    // New step for ESP-IDF v5+: configure the host
    sdmmc_host_t host_config = SDSPI_HOST_DEFAULT();
    host_config.slot = SPI2_HOST;

    sdspi_device_config_t slot_config = SDSPI_DEVICE_CONFIG_DEFAULT();
    slot_config.gpio_cs = PIN_NUM_CS;
    slot_config.host_id = host_config.slot;

    ESP_LOGI(TAG, "Mounting filesystem");
    
    // 4. Mount the SD card (Notice the 5 arguments now: added &host_config)
    ret = esp_vfs_fat_sdspi_mount(mount_point, &host_config, &slot_config, &mount_config, &card);
    if (ret != ESP_OK) {
        ESP_LOGE(TAG, "Failed to mount filesystem.");
        return;
    }
    ESP_LOGI(TAG, "Filesystem mounted");

    // 5. Print card info
    sdmmc_card_print_info(stdout, card);

    // 6. Open a file for writing (append mode "a")
    ESP_LOGI(TAG, "Opening file %s/data.csv", mount_point);
    FILE *f = fopen("/sdcard/data.csv", "a");
    if (f == NULL) {
        ESP_LOGE(TAG, "Failed to open file for writing");
        return;
    }

    // 7. Write data to the CSV file
    fprintf(f, "ID,Temp,Status\n");
    fprintf(f, "1,25.5,OK\n");
    fclose(f);
    ESP_LOGI(TAG, "File written and closed");

    // 8. Unmount card (clean up)
    esp_vfs_fat_sdcard_unmount(mount_point, card);
    ESP_LOGI(TAG, "Card unmounted");
    
    // 9. Deinitialize the SPI bus
    spi_bus_free(SPI2_HOST);
}