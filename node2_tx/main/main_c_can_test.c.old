#include <stdio.h>
#include "freertos/FreeRTOS.h"
#include "freertos/task.h"
#include "driver/twai.h"
#include "esp_log.h"
#include "esp_random.h"

static const char *TAG = "CAN_TX";

#define TX_PIN 26
#define RX_PIN 25

void app_main(void)
{
    // 1. Initialize configuration structures
    twai_general_config_t g_config = TWAI_GENERAL_CONFIG_DEFAULT(TX_PIN, RX_PIN, TWAI_MODE_NORMAL);
    twai_timing_config_t t_config = TWAI_TIMING_CONFIG_500KBITS();
    twai_filter_config_t f_config = TWAI_FILTER_CONFIG_ACCEPT_ALL();

    // 2. Install TWAI driver
    if (twai_driver_install(&g_config, &t_config, &f_config) == ESP_OK) {
        ESP_LOGI(TAG, "Driver installed");
    } else {
        ESP_LOGE(TAG, "Failed to install driver");
        return;
    }

    // 3. Start TWAI driver
    if (twai_start() == ESP_OK) {
        ESP_LOGI(TAG, "Driver started");
    } else {
        ESP_LOGE(TAG, "Failed to start driver");
        return;
    }

    while (1) {
        // 4. Prepare message
        twai_message_t message;
        message.identifier = 0x123; // Message ID
        message.extd = 0;           // 0 for Standard ID (11-bit), 1 for Extended (29-bit)
        message.data_length_code = 4; // We will send 4 bytes
        
        // Generate a random number (e.g., between 0 and 999)
        uint32_t random_val = esp_random() % 1000; 
        
        // Break the 32-bit integer into 4 bytes for transmission
        message.data[0] = (random_val >> 24) & 0xFF;
        message.data[1] = (random_val >> 16) & 0xFF;
        message.data[2] = (random_val >> 8) & 0xFF;
        message.data[3] = random_val & 0xFF;

        // 5. Transmit message
        if (twai_transmit(&message, pdMS_TO_TICKS(1000)) == ESP_OK) {
            ESP_LOGI(TAG, "Message sent: %lu", random_val);
        } else {
            ESP_LOGE(TAG, "Failed to send message");
        }

        vTaskDelay(pdMS_TO_TICKS(1000));
    }
}